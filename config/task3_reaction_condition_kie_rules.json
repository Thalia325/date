{
  "task": "task3_reaction_condition_experiment_parameter_kie",
  "goal": "Keep chemistry and chemical-engineering records useful for reaction-condition or experimental-parameter KIE.",
  "raw_data_roots": [
    "data/raw/ChemTable",
    "data/raw/ChemTables",
    "data/raw/ChEMU",
    "data/raw/ORD",
    "data/raw/ORDerly",
    "data/raw/SolidStateSynthesisRecipes"
  ],
  "target_outputs": [
    "data/reports/task3_local_audit.md",
    "data/processed/task3_dataset_manifest.csv",
    "data/processed/task3_kie_schema.json"
  ],
  "target_schema": {
    "record_id": "string",
    "source_dataset": "string",
    "source_document_id": "string|null",
    "source_table_id": "string|null",
    "source_row_id": "string|null",
    "experiment_id": "string|null",
    "table_type": "condition_optimization|substrate_screening|reaction_feature|synthesis_recipe|patent_reaction_step|ord_reaction|null",
    "reactants": "array<object{name, smiles, role, amount, unit, evidence}>",
    "products": "array<object{name, smiles, role, yield, unit, evidence}>",
    "catalysts": "array<object{name, amount, unit, evidence}>",
    "reagents": "array<object{name, amount, unit, evidence}>",
    "solvents": "array<object{name, amount, unit, evidence}>",
    "temperature": "object{value, unit, range, evidence}|null",
    "time": "object{value, unit, range, evidence}|null",
    "ph": "object{value, evidence}|null",
    "pressure": "object{value, unit, evidence}|null",
    "yield": "object{value, unit, evidence}|null",
    "selectivity": "object{value, unit, evidence}|null",
    "conversion": "object{value, unit, evidence}|null",
    "molar_ratio": "array<object{left, right, value, evidence}>",
    "operation": "array<object{name, conditions, evidence}>",
    "balanced_equation": "string|null",
    "evidence": "array<object{page, bbox, cell, text}>",
    "quality_flags": "array<string>"
  },
  "keep_keywords": [
    "reaction",
    "condition",
    "optimization",
    "optimisation",
    "substrate",
    "screening",
    "synthesis",
    "catalyst",
    "reagent",
    "solvent",
    "temperature",
    "temp",
    "time",
    "pressure",
    "yield",
    "selectivity",
    "conversion",
    "equiv",
    "molar",
    "stoichiometry",
    "ph",
    "entry",
    "product",
    "reactant",
    "starting material",
    "reaction product",
    "reagent catalyst",
    "solid-state",
    "calcination",
    "annealing"
  ],
  "drop_keywords": [
    "bibliography",
    "author contribution",
    "funding",
    "statistics only",
    "data statistics",
    "toc",
    "contents"
  ],
  "field_aliases": {
    "experiment_id": ["entry", "run", "trial", "experiment", "example", "exp no"],
    "reactants": ["reactant", "substrate", "starting material", "starting compound", "starting_compounds"],
    "products": ["product", "reaction product", "target material", "target_material"],
    "catalysts": ["catalyst", "ligand", "photocatalyst", "enzyme"],
    "reagents": ["reagent", "base", "additive", "oxidant", "reductant", "reagent catalyst"],
    "solvents": ["solvent", "solvents"],
    "temperature": ["temperature", "temp", "deg c", "celsius", "k"],
    "time": ["time", "duration", "h", "min", "hour"],
    "ph": ["ph", "pH"],
    "pressure": ["pressure", "atm", "bar", "mpa", "psi"],
    "yield": ["yield", "yield percent", "yield_percent", "yield_other"],
    "selectivity": ["selectivity", "ee", "er", "dr", "e/z", "regioselectivity"],
    "conversion": ["conversion", "conv"],
    "molar_ratio": ["molar ratio", "ratio", "equiv", "equivalent", "stoichiometry"],
    "operation": ["operation", "operations", "heat", "mix", "stir", "anneal", "calcine"],
    "balanced_equation": ["balanced equation", "balanced_equation", "equation"]
  },
  "datasets": {
    "ChemTable": {
      "roots": ["data/raw/ChemTable"],
      "role": "primary_visual_table_kie",
      "source_url": "https://github.com/lqzxt/ChemTable",
      "source_notes": "Real-world chemical table benchmark with table recognition and table understanding annotations; arXiv page is https://arxiv.org/abs/2506.11375.",
      "expected_paths": ["images", "annotations"],
      "priority": "P0",
      "keep_table_types": [
        "condition optimisation tables",
        "condition optimization tables",
        "substrate screening tables",
        "reaction feature data tables"
      ],
      "conditional_keep_table_types": [
        "property/result comparison tables",
        "chemical structure information tables"
      ],
      "drop_table_types": ["data statistics tables"],
      "recommended_use": [
        "reaction-condition table recognition",
        "substrate-screening row extraction",
        "cell-level evidence for KIE",
        "question-answer validation over extracted fields"
      ],
      "limitations": [
        "Benchmark annotations may not directly match the target KIE schema.",
        "Requires conversion from table/cell/QA annotation to row-level reaction-condition JSON."
      ],
      "first_pass_decision": "keep_core_if_local_annotations_exist"
    },
    "ChemTables": {
      "roots": ["data/raw/ChemTables"],
      "role": "table_type_classifier",
      "source_url": "https://data.mendeley.com/datasets/g7tjh7tbrj",
      "source_notes": "Chemical patent table semantic classification dataset. Public sample/standard split is described in the paper at https://jcheminf.biomedcentral.com/articles/10.1186/s13321-021-00568-2; full sample page notes 7,886 patent tables and a 10% public sample.",
      "expected_paths": ["train", "dev", "test"],
      "priority": "P1",
      "keep_table_types": [
        "reaction table",
        "compound table",
        "physical property table",
        "pharmacological effect table"
      ],
      "conditional_keep_table_types": [
        "spectral data table",
        "analytical data table"
      ],
      "recommended_use": [
        "front-end routing to decide which patent tables deserve KIE",
        "negative sampling for non-reaction tables"
      ],
      "limitations": [
        "Mostly table-level semantic labels, not field-level KIE.",
        "Patent-domain table language differs from journal reaction-optimization tables."
      ],
      "first_pass_decision": "keep_as_classifier_not_field_ground_truth"
    },
    "ChEMU": {
      "roots": ["data/raw/ChEMU"],
      "role": "patent_text_entity_event_kie",
      "source_url": "https://researchcollaborations.elsevier.com/en/datasets/chemu-dataset-for-information-extraction-from-chemical-patents/",
      "source_notes": "Chemical patent snippets with entities and reaction event steps.",
      "expected_paths": ["train", "dev", "test"],
      "priority": "P0",
      "keep_entity_types": [
        "STARTING_MATERIAL",
        "REAGENT_CATALYST",
        "REACTION_PRODUCT",
        "SOLVENT",
        "TEMPERATURE",
        "TIME",
        "YIELD_PERCENT",
        "YIELD_OTHER",
        "OTHER_COMPOUND"
      ],
      "recommended_use": [
        "text-side reaction-step extraction",
        "condition entity normalisation",
        "patent paragraph KIE to complement table KIE"
      ],
      "limitations": [
        "Text snippets rather than visual table images.",
        "Does not preserve table cell or bbox evidence."
      ],
      "first_pass_decision": "keep_core_for_text_kie_and_entity_mapping"
    },
    "ORD_OR_ORderly": {
      "roots": ["data/raw/ORD", "data/raw/ORDerly"],
      "role": "structured_reaction_schema_and_benchmark",
      "source_url": "https://github.com/sustainable-processes/ORDerly",
      "source_notes": "ORDerly extracts and cleans Open Reaction Database records and provides reaction benchmarks.",
      "expected_paths": ["data", "ord-data", "condition_prediction"],
      "priority": "P1",
      "keep_record_types": [
        "structured reaction",
        "condition prediction benchmark",
        "yield benchmark"
      ],
      "recommended_use": [
        "target schema design",
        "normalisation vocabulary for solvents/reagents/products/yields",
        "post-extraction consistency checks"
      ],
      "limitations": [
        "Not an OCR or visual-table dataset.",
        "Use as structured target and validation set, not as table-recognition ground truth."
      ],
      "first_pass_decision": "keep_as_schema_and_standardisation_reference"
    },
    "SolidStateSynthesisRecipes": {
      "roots": ["data/raw/SolidStateSynthesisRecipes", "data/raw/solid-state-synthesis-recipes"],
      "role": "materials_synthesis_recipe_kie",
      "source_url": "https://www.nature.com/articles/s41597-019-0224-1",
      "source_notes": "Text-mined inorganic solid-state synthesis recipes with JSON entries.",
      "expected_paths": ["*.json"],
      "priority": "P1",
      "keep_record_types": [
        "synthesis entry",
        "target material",
        "starting compounds",
        "operations",
        "conditions",
        "balanced chemical equation"
      ],
      "recommended_use": [
        "experimental-operation and condition schema reference",
        "materials synthesis KIE samples",
        "temperature/time/operation normalisation"
      ],
      "limitations": [
        "Mostly inorganic materials synthesis text, not reaction-condition table images.",
        "Organic reaction roles such as catalyst and solvent may be sparse."
      ],
      "first_pass_decision": "keep_for_experiment_parameter_schema_reference"
    }
  }
}
